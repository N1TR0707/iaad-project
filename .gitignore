# Git Ignore untuk IAAD-PROJECT
# File-file ini TIDAK akan di-commit ke GitHub

# Environment variables (PENTING: jangan commit!)
.env
.env.local
.env.production

# Dependencies
node_modules/
package-lock.json

# Database (jangan commit database production!)
*.db
*.db-journal
backend/database.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pm2-*.log

# Uploads & Backups
uploads/*
backup/*

# Keep directory structure but ignore contents
!uploads/.gitkeep
!backup/.gitkeep
!logs/.gitkeep

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
.cache/

# PM2
.pm2/
pids/
*.pid
*.seed
*.pid.lock
nul
